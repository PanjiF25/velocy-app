rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function userRole() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? userDoc(request.auth.uid).data.role
        : null;
    }

    function isOfficer() {
      return userRole() == 'officer';
    }

    match /users/{userId} {
      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'user'
        && request.resource.data.keys().hasOnly(['role', 'displayName', 'email', 'phone', 'createdAt', 'updatedAt']);

      allow read: if signedIn() && (request.auth.uid == userId || isOfficer());

      allow update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;

      allow delete: if false;
    }

    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly(['userId', 'tripId', 'description', 'status', 'createdAt']);

      allow read: if signedIn()
        && (resource.data.userId == request.auth.uid || isOfficer());

      allow update, delete: if signedIn() && isOfficer();
    }

    match /stations/{stationId} {
      allow read: if signedIn();
      allow write: if isOfficer();
    }

    match /docks/{dockId} {
      allow read: if signedIn();
      allow write: if isOfficer();
    }

    match /trips/{tripId} {
      allow read: if signedIn() && (resource.data.userId == request.auth.uid || isOfficer());
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if signedIn() && (resource.data.userId == request.auth.uid || isOfficer());
      allow delete: if false;
    }
  }
}
